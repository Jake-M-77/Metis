// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================
// Overview Tables
// =========================

// =========================
// CORE ENTITY
// =========================

model Person {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  birthDate DateTime
  sex       String
  ethnicity String
  pncId     String? //This will need to be made to be nullable by default as not all records will have a PNC ID
  createdAt DateTime @default(now())

  comms             Comms[]
  warningMarkers    WarningMarker[]
  bailConditions    BailCondition[]
  persondescription PersonDescription[]
  personAlias       PersonAlias[]
  custodyPhotos     CustodyPhoto[]
  document          Document[]
  personInfo        PersonInfo?
  address           PersonAddress[]
  
  sourceRelations PersonAssociation[] @relation("SourcePerson")
  targetRelations PersonAssociation[] @relation("TargetPerson")


}

model Comms {
  id           String   @id @default(uuid())
  contactType  String
  contactValue String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model Address {
  id           String       @id @default(uuid())
  houseNumber  Int?
  houseName    String?
  flatNumber   String?
  streetName   String
  townOrCity   String
  county       String
  postCode     String
  propertyType PropertyType @default(HOUSE)
  notes        String?
  createdAt    DateTime     @default(now())

  personAddresses PersonAddress[]
}

model WarningMarker {
  id           String     @id @default(uuid())
  markerType   MarkerType @default(INFO)
  description  String
  enteredBy    String
  dateRecorded DateTime   @default(now())
  createdAt    DateTime   @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model BailCondition {
  id            String        @id @default(uuid())
  conditionType ConditionType @default(OTHER)
  startDate     DateTime      @default(now())
  endDate       DateTime?
  imposedBy     String
  description   String
  createdAt     DateTime      @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model PersonDescription {
  id             String         @id @default(uuid())
  descriptorType DescriptorType @default(IDENTIFIER)
  description    String
  imageURL       String
  enteredBy      String
  updatedAt      DateTime //possibly change this to where its needed for UPDATE but not CREATE
  createdAt      DateTime       @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model PersonAlias {
  id           String    @id @default(uuid())
  aliasName    String
  aliasDob     DateTime?
  notes        String?
  enteredBy    String
  dateRecorded DateTime  @default(now())
  createdAt    DateTime  @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model CustodyPhoto {
  id         String    @id @default(uuid())
  imageUrl   String
  dateTaken  DateTime?
  uploadedBy String
  notes      String?
  createdAt  DateTime  @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model Document {
  id           String       @id @default(uuid())
  documentType DocumentType @default(OTHER)
  fileName     String
  fileUrl      String
  uploadedBy   String
  uploadDate   DateTime
  expiryDate   DateTime?
  notes        String?
  createdAt    DateTime     @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String
}

model PersonInfo {
  id               String   @id @default(uuid())
  recordCreatedBy  String
  sourceSystem     String
  lastModifiedBy   String
  lastModifiedDate DateTime
  changeNotes      String?
  createdAt        DateTime @default(now())

  person   Person @relation(fields: [personId], references: [id])
  personId String @unique
}

// =========================
// RELATIONSHIP TABLES
// =========================

model PersonAddress {
  id String @id @default(uuid())

  person   Person @relation(fields: [personId], references: [id])
  personId String

  address   Address @relation(fields: [addressId], references: [id])
  addressId String

  relationshipType RelationshipType @default(RESIDES)

  startDate DateTime  @default(now())
  endDate   DateTime?

  notes String?

  createdAt DateTime @default(now())
}

// =========================
// ENUMS
// =========================

enum PropertyType {
  HOUSE
  FLAT
  HMO
  CARAVAN
}

enum RelationshipType {
  RESIDES
  LAST_KNOWN
  PREVIOUS_ADDRESS
}

enum MarkerType {
  INFO
}

enum ConditionType {
  OTHER
  POLICE_BAIL
  COURT_BAIL
}

enum DescriptorType {
  IDENTIFIER
}

enum DocumentType {
  OTHER
}

// =========================
// End of Overview Tables
// =========================

// =========================
// People Table page
// =========================

model PersonAssociation {
  id String @id @default(uuid())

  sourcePersonId String
  sourcePerson   Person @relation("SourcePerson", fields: [sourcePersonId], references: [id])

  targetPersonId String
  targetPerson   Person @relation("TargetPerson", fields: [targetPersonId], references: [id])

  relationType RelationType @default(UNKNOWN)

  createdAt DateTime @default(now())

}

enum RelationType {
  UNKNOWN
}

// =========================
// End of People Table page
// =========================
